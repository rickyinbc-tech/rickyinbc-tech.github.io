{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "rickykwok-edge-redirects",
  "main": "cloudflare-worker.mjs",
  "compatibility_date": "2026-07-11",
  "workers_dev": false,
  "routes": [
    { "pattern": "wine.rickykwok.com/*", "zone_name": "rickykwok.com" },
    { "pattern": "rickykwok.com/*", "zone_name": "rickykwok.com" },
    { "pattern": "*.rickykwok.com/*", "zone_name": "rickykwok.com" }
  ]
}
